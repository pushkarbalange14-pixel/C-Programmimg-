Description  : This program finds the smallest element in an array.
==========================================
*/

#include <stdio.h>

int main() {
    int n, i;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    int arr[n];

    printf("Enter the elements:\n");
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int smallest = arr[0];

    for (i = 1; i < n; i++) {
        if (arr[i] < smallest)
            smallest = arr[i];
    }

    printf("Smallest element = %d\n", smallest);

    return 0;
}
